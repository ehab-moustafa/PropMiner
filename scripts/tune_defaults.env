# PropMiner fleet defaults — override after tune on your hardware.
# Source before mining:  set -a && source scripts/tune_defaults.env && set +a
#
# After tune:  source ~/.cache/propminer/tune_full_result.env

PROPMINER_N_CAP=131072
PROPMINER_BATCH=32
PROPMINER_GRAPH_BATCH=8
PEARL_GEMM_CONSUMER_CLUSTER_M=1
PROPMINER_STALL_RESTART_MS=30000
PROPMINER_STALL_RESTART_DELAY_SEC=3
PROPMINER_AUTOTUNE=0
PROPMINER_USE_TUNE_CACHE=0
