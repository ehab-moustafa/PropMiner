# PropMiner → Kryptex PRL (direct mining, Europe-first)
# https://www.kryptex.com/en/articles/kryptex-pools-direct-mining-en
#
# Copy into Salad / Docker env. Stratum :7048 is required (gRPC :443 often 503).

PROPMINER_MODE=mine
PROPMINER_WALLET=krxX2P3Z84
PROPMINER_WORKER=prop-miner-high

# gRPC fallback only (unused while PROPMINER_USE_STRATUM=1)
PROPMINER_POOL=prl-eu.kryptex.network:443,prl.kryptex.network:443

# Primary path — EU first, global fallback
PROPMINER_USE_STRATUM=1
PROPMINER_STRATUM_POOL=prl-eu.kryptex.network:7048,prl.kryptex.network:7048
PROPMINER_STRATUM_PASSWORD=x

# pearl/v1 positional submit is default on Kryptex :7048 (object form rejected).
# PROPMINER_STRATUM_OBJECT_SUBMIT=1  # suprnova-style pools only

# Do not set PROPMINER_STRATUM_DIFF unless you need static vardiff (e.g. 262144 on 5090).
# PROPMINER_STRATUM_DIFF=262144

PROPMINER_GPUS=0
PEARL_GEMM_CONSUMER_CLUSTER_M=1
PROPMINER_USE_TUNE_CACHE=1
PROPMINER_CLAIMED_TMAD=15

CUDA_MODULE_LOADING=EAGER
CUDA_DEVICE_MAX_CONNECTIONS=1
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

PROPMINER_USE_RELEASE=1
PROPMINER_RELEASE_TAG=continuous
PROPMINER_AUTO_UPDATE=1
PROPMINER_RESTART_ON_EXIT=1

PROPMINER_GRPC_TIMEOUT_MS=30000
PROPMINER_POOL_BACKOFF_MAX_MS=120000
PROPMINER_VERBOSE_SHARES=1
PROPMINER_VERBOSE_STRATUM=1

# Never set on production (graphs must stay enabled):
# PROPMINER_BENCH_NO_GRAPH=1
