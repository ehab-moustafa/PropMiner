# PropMiner → Kryptex PRL (direct mining, Europe-first)
# https://pool.kryptex.com/prl  (see also /articles/pearl-miners-en)
#
# Copy into Salad / Docker env. Kryptex Pearl is STRATUM-ONLY:
#   prl.kryptex.network:7048  (TCP)   /   :8048  (SSL)
# There is NO gRPC :443 endpoint for PRL, so we run Stratum directly.

PROPMINER_MODE=mine
# Your Kryptex Mining Username (Profile page), SRB-style with worker suffix:
#   krxXXXXXX.propminer5090   (same as SRBMiner --wallet krxXXXXXX.worker)
# Or split: PROPMINER_WALLET=krxXXXXXX  PROPMINER_WORKER=propminer5090
PROPMINER_WALLET=krxXXXXXX.propminer5090

# Primary path — Stratum, EU first with global fallback.
PROPMINER_USE_STRATUM=1
PROPMINER_STRATUM_POOL=prl-eu.kryptex.network:7048,prl.kryptex.network:7048
PROPMINER_STRATUM_PASSWORD=x

# Object mining.submit {job_id, plain_proof} is the default for Kryptex object-notify.
# Only pearl/v1 challenge pools need positional — set PROPMINER_STRATUM_OBJECT_SUBMIT=0.
# Stratum pools require K>=1024 in PlainProof (auto K=4096 when PROPMINER_USE_STRATUM=1).
# PROPMINER_STRATUM_K=4096   PROPMINER_STRATUM_RANK=128
# PROPMINER_CHALLENGE_WAIT_MS=2000    # how long to wait for pearl.challenge
# PROPMINER_CHALLENGE_MAX_DIFF=44     # refuse to grind harder challenges

# Do not set PROPMINER_STRATUM_DIFF unless you need static vardiff (e.g. 262144 on 5090).
# PROPMINER_STRATUM_DIFF=262144

PROPMINER_GPUS=0
PEARL_GEMM_CONSUMER_CLUSTER_M=1
PROPMINER_USE_TUNE_CACHE=1
PROPMINER_CLAIMED_TMAD=15

CUDA_MODULE_LOADING=EAGER
CUDA_DEVICE_MAX_CONNECTIONS=1
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

PROPMINER_USE_RELEASE=1
PROPMINER_RELEASE_TAG=continuous
PROPMINER_AUTO_UPDATE=1
PROPMINER_RESTART_ON_EXIT=1

PROPMINER_GRPC_TIMEOUT_MS=30000
PROPMINER_POOL_BACKOFF_MAX_MS=120000
PROPMINER_VERBOSE_SHARES=1
PROPMINER_VERBOSE_STRATUM=1

# Never set on production (graphs must stay enabled):
# PROPMINER_BENCH_NO_GRAPH=1
