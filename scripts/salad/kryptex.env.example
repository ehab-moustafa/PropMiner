# PropMiner → Kryptex PRL (direct mining)
# https://pool.kryptex.com/prl

PROPMINER_MODE=mine
PROPMINER_WALLET=krxXXXXXX.propminer5090

# Stratum (default): global first, EU fallback. Kryptex PRL is Stratum-only (:7048).
PROPMINER_USE_STRATUM=1
PROPMINER_STRATUM_POOL=prl.kryptex.network:7048,prl-eu.kryptex.network:7048
PROPMINER_STRATUM_PASSWORD=x
# Share difficulty: lower = easier shares (wire: password x;d=N). Default 32768 in binary.
PROPMINER_STRATUM_DIFF=32768
# Committed stratum shape: the binary now mines the canonical HeroMiners/Kryptex
# shape M=N=131072, K=4096, noise_rank=256 (matches ARC/Akoya). The pool validates
# these against its network mining params; a mismatch rejects every share.
# Escape hatches (only if you know the pool's params differ — otherwise leave unset):
# PROPMINER_STRATUM_M=131072
# PROPMINER_STRATUM_N=131072
# PROPMINER_STRATUM_K=4096
# PROPMINER_STRATUM_RANK=256      # 128 or 256 only
#
# Hash tile index mode: the pool verifier re-derives opened rows/cols as
# rows_pattern/cols_pattern + origin, so the canonical PATTERN mode must be ON
# (extract mode opens the wrong leaves on the Blackwell kernel → Invalid share).
PROPMINER_HASH_TILE_PATTERN=1
# Canonical shape needs ARC-style mpp=1 and a long watchdog (default ~300s budget).
# Override only if you know iter_ms: PROPMINER_BATCH=1 PROPMINER_GRAPH_BATCH=1
# PROPMINER_WATCHDOG_PERIOD_MS=100000
# Cluster M: default 1 in binary (share-safe). Set PEARL_GEMM_CONSUMER_CLUSTER_M=4 only after pattern mode works.
# Anti-ban circuit breaker: after N consecutive pool rejects, PropMiner halts
# submissions + reconnects and logs it (restart to resume). Default 3; 0 disables.
# PROPMINER_MAX_CONSECUTIVE_REJECTS=3

# GPUs: omit PROPMINER_GPUS to use all visible GPUs (default).
# PROPMINER_GPUS=0,1

# Tuning: run salad-tune once, then mine with cache only.
PROPMINER_USE_TUNE_CACHE=1
PROPMINER_AUTOTUNE=0

PROPMINER_USE_RELEASE=1
PROPMINER_RELEASE_TAG=continuous
PROPMINER_AUTO_UPDATE=1
PROPMINER_RESTART_ON_EXIT=1

CUDA_MODULE_LOADING=EAGER
CUDA_DEVICE_MAX_CONNECTIONS=1
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

PROPMINER_VERBOSE_SHARES=1
PROPMINER_VERBOSE_STRATUM=1
