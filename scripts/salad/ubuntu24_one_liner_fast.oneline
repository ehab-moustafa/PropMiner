# Salad: image ubuntu:24.04
# Env: PROPMINER_WALLET=krxYOURUSER  and optionally PROPMINER_WORKER=rig01
# Total download ~3 MB (cudart + miner) — similar to SRBMiner ~18 MB.
# Paste ONE of the lines below as the startup command.

# Recommended — pulls maintained script from GitHub (~3 KB):
export DEBIAN_FRONTEND=noninteractive && apt-get update && apt-get install -y curl ca-certificates libssl3 xz-utils && curl -fsSL --retry 5 --retry-delay 3 https://raw.githubusercontent.com/ehab-moustafa/PropMiner/master/scripts/salad/ubuntu24_one_liner_fast.sh | bash; sleep infinity

# Fully inlined fallback — no script download:
export DEBIAN_FRONTEND=noninteractive && apt-get update && apt-get install -y curl ca-certificates libssl3 xz-utils && CUDA_ROOT=/usr/local/cuda-12.8/targets/x86_64-linux && CUDA_LIB="$CUDA_ROOT/lib" && mkdir -p "$CUDA_ROOT" /usr/local/cuda/lib64 /opt/propminer && BASE=https://developer.download.nvidia.com/compute/cuda/redist && cd /tmp && echo "[cuda] cuda_cudart" && curl -fsSL --retry 5 --retry-delay 3 -o cuda_cudart.tar.xz $BASE/cuda_cudart/linux-x86_64/cuda_cudart-linux-x86_64-12.8.57-archive.tar.xz && tar -xf cuda_cudart.tar.xz --strip-components=1 -C "$CUDA_ROOT" && cd "$CUDA_LIB" && ln -sf libcudart.so.12.8.57 libcudart.so.12 && ln -sf libcudart.so.12.8.57 libcudart.so && ln -sf "$CUDA_LIB/libcudart.so.12" /usr/local/cuda/lib64/libcudart.so.12 && ln -sf "$CUDA_LIB/libcudart.so.12" /usr/local/cuda/lib64/libcudart.so && echo "[release] propminer" && curl -fsSL --retry 5 -o /tmp/pm.tar.gz https://github.com/ehab-moustafa/PropMiner/releases/download/continuous/propminer-rtx5090-linux-amd64.tar.gz && tar xzf /tmp/pm.tar.gz -C /opt/propminer && chmod +x /opt/propminer/propminer && export LD_LIBRARY_PATH="/opt/propminer:$CUDA_LIB:/usr/local/cuda/lib64" NVIDIA_VISIBLE_DEVICES=all NVIDIA_DRIVER_CAPABILITIES=compute,utility CUDA_MODULE_LOADING=EAGER CUDA_DEVICE_MAX_CONNECTIONS=1 PEARL_GEMM_CONSUMER_CLUSTER_M=2 && if [ -e /dev/dxg ]; then for so in /usr/lib/x86_64-linux-gnu/libdxcore.so /usr/lib/wsl/drivers/*/libnvdxgdmal.so.1 /usr/lib/wsl/drivers/*/libcuda_loader.so /usr/lib/wsl/drivers/*/libnvidia-ml_loader.so /usr/lib/wsl/drivers/*/libcuda.so.1.1; do [ -f $so ] && export LD_PRELOAD="${LD_PRELOAD:+$LD_PRELOAD:}$so"; done; export LD_LIBRARY_PATH="/opt/propminer:$CUDA_LIB:/usr/local/cuda/lib64:/usr/lib/wsl/drivers:$LD_LIBRARY_PATH"; echo "[env] WSL2 /dev/dxg"; fi && cd /opt/propminer && if [ -n "$PROPMINER_WALLET" ]; then WORKER_ARGS=""; [ -n "$PROPMINER_WORKER" ] && WORKER_ARGS="--worker $PROPMINER_WORKER"; while true; do ./propminer --rtx5090 --gpus 0 --pool prl.kryptex.network:443,prl-eu.kryptex.network:443 --wallet "$PROPMINER_WALLET" $WORKER_ARGS || true; echo "[mine] restart in 10s"; sleep 10; done; else echo "ERROR: set PROPMINER_WALLET env var"; fi; sleep infinity
