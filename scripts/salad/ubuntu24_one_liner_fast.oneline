# Salad: image ubuntu:24.04
# Env: PROPMINER_WALLET=krxYOURUSER  and optionally PROPMINER_WORKER=rig01
# Paste ONE of the lines below as the startup command.

# Recommended — pulls maintained script from GitHub (~3 KB):
export DEBIAN_FRONTEND=noninteractive && apt-get update && apt-get install -y curl ca-certificates libssl3 && curl -fsSL --retry 5 --retry-delay 3 https://raw.githubusercontent.com/ehab-moustafa/PropMiner/master/scripts/salad/ubuntu24_one_liner_fast.sh | bash; sleep infinity

# Fully inlined fallback — no script download (duplicate of ubuntu24_one_liner_fast.sh):
export DEBIAN_FRONTEND=noninteractive && apt-get update && apt-get install -y curl ca-certificates libssl3 && DEST=/usr/local/cuda-12.8/targets/x86_64-linux/lib && mkdir -p "$DEST" /usr/local/cuda/lib64 /opt/propminer && BASE=https://developer.download.nvidia.com/compute/cuda/redist && cd /tmp && for spec in cuda_cudart:12.8.57 cuda_nvrtc:12.8.61 libcublas:12.8.3.14 libnvjitlink:12.8.61; do n=${spec%%:*}; v=${spec#*:}; echo "[cuda] $n" && curl -fsSL --retry 5 --retry-delay 3 -o $n.tar.xz $BASE/$n/linux-x86_64/${n}-linux-x86_64-${v}-archive.tar.xz && tar -xf $n.tar.xz --strip-components=1 -C "$DEST"; done && cd "$DEST" && ln -sf libcudart.so.12.8.57 libcudart.so.12 && ln -sf libcudart.so.12.8.57 libcudart.so && ln -sf libnvrtc.so.12.8.61 libnvrtc.so.12 && ln -sf libcublas.so.12.8.3.14 libcublas.so.12 && ln -sf libcublasLt.so.12.8.3.14 libcublasLt.so.12 && ln -sf libnvJitLink.so.12.8.61 libnvJitLink.so.12 && for lib in libcudart libnvrtc libcublas libcublasLt libnvJitLink; do ln -sf "$DEST/${lib}.so.12" /usr/local/cuda/lib64/${lib}.so.12; done && echo "[release] propminer" && curl -fsSL --retry 5 -o /tmp/pm.tar.gz https://github.com/ehab-moustafa/PropMiner/releases/download/continuous/propminer-rtx5090-linux-amd64.tar.gz && tar xzf /tmp/pm.tar.gz -C /opt/propminer && chmod +x /opt/propminer/propminer && export LD_LIBRARY_PATH="$DEST:/usr/local/cuda/lib64:/opt/propminer" NVIDIA_VISIBLE_DEVICES=all NVIDIA_DRIVER_CAPABILITIES=compute,utility CUDA_MODULE_LOADING=EAGER CUDA_DEVICE_MAX_CONNECTIONS=1 PEARL_GEMM_CONSUMER_CLUSTER_M=2 && if [ -e /dev/dxg ]; then export LD_LIBRARY_PATH="/usr/lib/wsl/drivers:$LD_LIBRARY_PATH"; for so in /usr/lib/x86_64-linux-gnu/libdxcore.so /usr/lib/wsl/drivers/*/libnvdxgdmal.so.1 /usr/lib/wsl/drivers/*/libcuda_loader.so; do [ -f $so ] && export LD_PRELOAD="${LD_PRELOAD:+$LD_PRELOAD:}$so"; done; fi && cd /opt/propminer && if [ -n "$PROPMINER_WALLET" ]; then WORKER_ARGS=""; [ -n "$PROPMINER_WORKER" ] && WORKER_ARGS="--worker $PROPMINER_WORKER"; while true; do ./propminer --rtx5090 --gpus 0 --pool prl.kryptex.network:443,prl-eu.kryptex.network:443 --wallet "$PROPMINER_WALLET" $WORKER_ARGS || true; echo "[mine] restart in 10s"; sleep 10; done; else echo "ERROR: set PROPMINER_WALLET env var"; fi; sleep infinity
